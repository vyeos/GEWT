{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GEWT",
  "version": "0.1.1",
  "identifier": "com.vyeos.gewt",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GEWT",
        "height": 600,
        "width": 800,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJFRTQ1NjBCQ0Y3MzU2OEYKUldTUFZuUFBDMWJrTHAxRm1HWjRuRnAveEZUUVBFYjFHZG9iM2NXbDVSZWpnRjlEU09SYVg2NzkK",
      "endpoints": [
        "https://github.com/vyeos/GEWT/releases/latest/download/latest.json"
      ]
    }
  }
}
